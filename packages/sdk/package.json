{
  "name": "@spectre-protocol/sdk",
  "version": "0.1.2",
  "publishConfig": {
    "access": "public"
  },
  "description": "SDK for Spectre Protocol — ZK account recovery for AI agents on Base",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "sync:docs": "npm run build && rm -rf ../../docs/sdk && mkdir -p ../../docs/sdk && cp -r dist/. ../../docs/sdk/"
  },
  "keywords": [
    "zk",
    "account-recovery",
    "base",
    "noir",
    "world-id",
    "ai-agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CECILIA-MULANDI/spectre-protocol-base-evm"
  },
  "dependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@noir-lang/backend_barretenberg": "^0.36.0",
    "@noir-lang/noir_js": "^1.0.0-beta.20",
    "@types/node": "^25.6.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@noir-lang/noir_js": {
      "optional": true
    },
    "@noir-lang/backend_barretenberg": {
      "optional": true
    }
  }
}
