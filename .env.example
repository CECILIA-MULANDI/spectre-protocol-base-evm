# ── Foundry deploy script ────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x

# World ID Router — Base Sepolia: 0x42FF98C4E85212a5D31358ACbFe76a621b784Fac
# World ID Router — Base Mainnet: 0x57f928158C3EE7CDad1e4D8642503c4D0201f611
WORLD_ID_ROUTER=0x

# 1 = Orb-verified (default for testnet and mainnet)
WORLD_ID_GROUP_ID=1

# RPC endpoints (referenced in foundry.toml)
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=https://mainnet.base.org

# Basescan API key for --verify
BASESCAN_API_KEY=

# ── Relayer CLI (relayer/config.json) ────────────────────────────────────────
# After deploying, copy these values into relayer/config.json
# REGISTRY_ADDRESS=0x          (SpectreRegistry)
# VERIFIER_ADDRESS=0x          (HonkVerifier)
# OWNER_PRIVATE_KEY=0x
